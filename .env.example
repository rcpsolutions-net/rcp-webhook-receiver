# Server
HOST=0.0.0.0
PORT=3000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ── Per-provider webhook configuration ────────────────────────────────────────
#
# For each provider, set the following environment variables
# (replace PROVIDER with the uppercase provider name):
#
#   WEBHOOK_SECRET_<PROVIDER>  - Shared HMAC secret (required)
#   WEBHOOK_HEADER_<PROVIDER>  - Signature header name
#                                (optional, defaults to x-hub-signature-256)
#   WEBHOOK_MODE_<PROVIDER>    - "immediate" or "queue"
#                                (optional, defaults to "immediate")
#
# Examples:

WEBHOOK_SECRET_GITHUB=your-github-webhook-secret
WEBHOOK_HEADER_GITHUB=x-hub-signature-256
WEBHOOK_MODE_GITHUB=immediate

WEBHOOK_SECRET_STRIPE=your-stripe-webhook-secret
WEBHOOK_HEADER_STRIPE=x-stripe-signature
WEBHOOK_MODE_STRIPE=queue
