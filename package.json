{
  "name": "rcp-webhook-receiver",
  "version": "1.0.0",
  "description": "RCP v4.2 incoming third-party webhook handler",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "test": "npm run build && tap dist/test/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcpsolutions-net/rcp-webhook-receiver.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rcpsolutions-net/rcp-webhook-receiver/issues"
  },
  "homepage": "https://github.com/rcpsolutions-net/rcp-webhook-receiver#readme",
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "tap": "^21.6.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "tap": {
    "include": [
      "dist/test/**/*.test.js"
    ],
    "statements": 80,
    "branches": 75,
    "lines": 80,
    "functions": 80
  }
