{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
 
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
